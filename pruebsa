const WebSocket = require('ws');
const Sala = require('./game/sala');

const wss = new WebSocket.Server({ port: 3000 });
const sala = new Sala();

console.log("Servidor en ws://localhost:3000");

wss.on('connection', (ws) => {
    console.log("Conexió feta");

    // 1. ENVIAR LA LLISTA NOMÉS EN CONNECTAR-SE
    // Això envia la llista només al nou client que acaba d'arribar
    ws.send(JSON.stringify({
        type: "PLAYER_LIST",
        data: sala.getPlayerList() 
    }));

    let myId = null;

    ws.on('message', (message) => {
        let msg;
        
        // [ELIMINAT] Aquí ja no enviem PLAYER_LIST, era redundant!

        try {
            msg = JSON.parse(message);
        } catch {
            console.log("JSON inválido");
            return;
        }

        // JOIN
        if (msg.type === "JOIN") {
            myId = Math.random().toString(36).substring(2, 10);
            const result = sala.addPlayer(myId, msg.nickname, ws);

            if (!result.success) {
                ws.send(JSON.stringify({ type: "ERROR", message: result.message }));
                return;
            }

            console.log(`${msg.nickname} unido`);
            ws.send(JSON.stringify({ type: "WELCOME", id: myId }));

            // 2. AVISAR A TOTHOM QUE HA ENTRAT UN NOU
            // Només fem broadcast quan canvia l'estat de la sala
            sala.broadcast("PLAYER_LIST", sala.getPlayerList());
        }

        // INPUT
        if (msg.type === "INPUT") {
            const player = sala.getPlayer(myId);
            if (!player) return;

            player.input.left = msg.left;
            player.input.right = msg.right;
            player.input.jump = msg.jump;
        }
    });

    ws.on('close', () => {
        if (myId) {
            sala.removePlayer(myId);
            // 3. AVISAR A TOTHOM QUE HA SORTIT
            sala.broadcast("PLAYER_LIST", sala.getPlayerList());
            console.log(`Jugador ${myId} desconectado`);
        }
    });
});
ws.on('close', () => {
    if (myId) {
        // 1. Buscamos al jugador antes de eliminarlo para saber su nombre
        const player = sala.getPlayer(myId);
        const nickName = player ? player.nickname : "Desconocido";

        // 2. Eliminamos al jugador
        sala.removePlayer(myId);

        // 3. Avisamos a los demás usando su NICKNAME (mejor UX)
        // Puedes enviar un mensaje específico de desconexión
        sala.broadcast("PLAYER_LEFT", {
            id: myId,
            nickname: nickName
        });

        // 4. Actualizamos la lista general
        sala.broadcast("PLAYER_LIST", sala.getPlayerList());

        console.log(`Jugador ${nickName} (${myId}) desconectado`);
    }
});